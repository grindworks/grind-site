  "sidebar_custom_css": "border-right: 2px solid #000 !important; box-shadow: 4px 0px 0px 0px rgba(0,0,0,1) !important;",
  "css": "/* 8-bit Selection Color */\n::selection { background: #0000aa !important; color: #fff !important; }\n::-moz-selection { background: #0000aa !important; color: #fff !important; }\n\n/* Interactive Hover Lift for Panels */\n.bg-theme-surface, .card { transition: transform 0.1s ease-out, box-shadow 0.1s ease-out; }\n.bg-theme-surface:hover, .card:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0px 0px rgba(0,0,0,1); }\n\n/* Retro Scrollbar (Checkered Track) */\n::-webkit-scrollbar-track { background: url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI0IiBoZWlnaHQ9IjQiPjxyZWN0IHdpZHRoPSIyIiBoZWlnaHQ9IjIiIGZpbGw9IiNjY2MiLz48cmVjdCB4PSIyIiB5PSIyIiB3aWR0aD0iMiIgaGVpZ2h0PSIyIiBmaWxsPSIjY2NjIi8+PC9zdmc+') !important; }\n::-webkit-scrollbar-thumb { background: #000 !important; border: 1px solid #fff; border-radius: 0 !important; }\n\n/* Force Bold for Better Pixel Readability */\n* { font-weight: bold; }",
