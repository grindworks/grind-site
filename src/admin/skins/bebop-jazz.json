  "css": "body { background-color: #0e0e12; background-image: linear-gradient(45deg, #0e0e12 25%, #15151a 25%, #15151a 50%, #0e0e12 50%, #0e0e12 75%, #15151a 75%, #15151a 100%); background-size: 40px 40px; background-attachment: fixed; } .card, .panel, .surface { backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(45, 45, 58, 0.6) !important; } .sidebar { backdrop-filter: blur(20px); border-right: 1px solid rgba(45, 45, 58, 0.4) !important; } .header { backdrop-filter: blur(16px); border-bottom: 1px solid rgba(45, 45, 58, 0.6) !important; } .text-center .w-12.h-12 { background-color: #e53935; color: #fff; border-radius: 0; clip-path: polygon(0 0, 100% 0, 100% 80%, 80% 100%, 0 100%); animation: tank-jam 0.5s infinite alternate; } @keyframes tank-jam { 0% { transform: skewX(0deg); } 100% { transform: skewX(-5deg); } }",
