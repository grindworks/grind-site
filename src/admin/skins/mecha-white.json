  "css": ".card, .panel, .surface { backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(203, 213, 225, 0.5) !important; } .sidebar { backdrop-filter: blur(16px); border-right: 1px solid rgba(203, 213, 225, 0.4) !important; } .header { backdrop-filter: blur(12px); border-bottom: 1px solid rgba(203, 213, 225, 0.6) !important; } .text-center .w-12.h-12 { background-color: #ffffff; border: 2px solid #2563eb; border-radius: 4px; position: relative; overflow: hidden; box-shadow: 0 0 15px rgba(37, 99, 235, 0.3); } .text-center .w-12.h-12::before { content: ''; position: absolute; top: 30%; left: 50%; transform: translate(-50%, 0); width: 0; height: 0; border-left: 12px solid transparent; border-right: 12px solid transparent; border-top: 18px solid #fbbf24; } .text-center .w-12.h-12::after { content: ''; position: absolute; top: 30%; left: 50%; transform: translate(-50%, -50%); width: 8px; height: 8px; background-color: #ef4444; border-radius: 2px; }",
