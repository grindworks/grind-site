  "sidebar_custom_css": "",
  "css": "body { background-color: #000000; } .card, .panel, .surface { border: 2px solid #1919a6 !important; box-shadow: 0 0 0 2px #000000, 0 0 0 4px #1919a6; margin: 4px; } .sidebar { border-right: 4px double #1919a6 !important; } .header { border-bottom: 4px double #1919a6 !important; } input, select, textarea { border: 2px solid #1919a6 !important; font-family: \"Press Start 2P\", cursive; } .btn-primary { background: #ffff00 !important; color: #000000 !important; border: 2px solid #000000 !important; box-shadow: 4px 4px 0px #ffb8ff !important; } .btn-primary:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0px #ffb8ff !important; } .btn-secondary { border: 2px solid #ffb8ff !important; color: #ffb8ff !important; } ::selection { background: #ffff00; color: #000000; }",
